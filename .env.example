# Copy this file to .env and fill in values.
# Reddit collection uses the public JSON API — no API key required.

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite file in the project root.
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/senti_db
DATABASE_URL=sqlite:///./app.db

# ── (Future) Additional sources ───────────────────────────────────────────────
# Add credentials here when new sources are integrated.
# NEWSAPI_KEY=
# BLUESKY_APP_PASSWORD=
